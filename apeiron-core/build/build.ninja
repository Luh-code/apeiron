# Object build statements for STATIC_LIBRARY target glfw


#############################################
# Order-only phony target for glfw

build cmake_object_order_depends_target_glfw: phony || deps/glfw/src/wayland-client-protocol-code.h deps/glfw/src/wayland-client-protocol.h deps/glfw/src/wayland-idle-inhibit-unstable-v1-client-protocol-code.h deps/glfw/src/wayland-idle-inhibit-unstable-v1-client-protocol.h deps/glfw/src/wayland-pointer-constraints-unstable-v1-client-protocol-code.h deps/glfw/src/wayland-pointer-constraints-unstable-v1-client-protocol.h deps/glfw/src/wayland-relative-pointer-unstable-v1-client-protocol-code.h deps/glfw/src/wayland-relative-pointer-unstable-v1-client-protocol.h deps/glfw/src/wayland-viewporter-client-protocol-code.h deps/glfw/src/wayland-viewporter-client-protocol.h deps/glfw/src/wayland-xdg-decoration-client-protocol-code.h deps/glfw/src/wayland-xdg-decoration-client-protocol.h deps/glfw/src/wayland-xdg-shell-client-protocol-code.h deps/glfw/src/wayland-xdg-shell-client-protocol.h

build deps/glfw/src/CMakeFiles/glfw.dir/context.c.o: C_COMPILER__glfw_unscanned_ /media/para/Projects/apeiron/apeiron-core/deps/glfw/src/context.c || cmake_object_order_depends_target_glfw
  DEFINES = -DHAVE_MEMFD_CREATE -D_DEFAULT_SOURCE -D_GLFW_WAYLAND -D_GLFW_X11
