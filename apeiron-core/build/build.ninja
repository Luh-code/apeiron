# Utility command for uninstall

build deps/sdl2/uninstall: phony deps/sdl2/CMakeFiles/uninstall


#############################################
# Utility command for test

build deps/sdl2/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /media/para/Projects/apeiron/apeiron-core/build/deps/sdl2 && /usr/bin/ctest --force-new-ctest-process
